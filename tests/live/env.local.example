# Live cluster harness — local env template.
#
# Copy this to `env.local` (which IS gitignored) and fill in the
# values for your cluster. The mutation test sources it; missing or
# wrong values fail loudly via `: "${VAR:?msg}"` checks.
#
# ⚠️ Never commit a real token. An earlier revision of
# `test_mutation.sh` had one inline; we rotated + revoked it when
# discovered, but the leaked value still lives in public git history
# forever. Don't repeat the mistake — `tests/live/env.local` is
# gitignored on purpose.
#
# Token format: `tokenid=secret`. Example for `root@pam!proxxx`:
#   PROXXX_E2E_PVE_TOKEN="proxxx=00000000-0000-0000-0000-000000000000"

export PROXXX_E2E_PVE_URL="https://pve1.lan:8006"
export PROXXX_E2E_PVE_TOKEN="proxxx=00000000-0000-0000-0000-000000000000"
export PROXXX_E2E_NODE="pve1"

# Optional overrides (defaults in test_mutation.sh):
# export PROXXX_E2E_MUTATION_VMID=9999
# export PROXXX_E2E_LXC_TEMPLATE="local:vztmpl/alpine-3.22-default_20250617_amd64.tar.xz"
# export PROXXX_E2E_LXC_STORAGE="local-lvm"
#
# Batch 3 (QEMU lifecycle) overrides:
# export PROXXX_E2E_QEMU_VMID=9998
# export PROXXX_E2E_QEMU_ISO="local:iso/alpine-standard-3.23.4-x86_64.iso"
# export PROXXX_E2E_QEMU_STORAGE="local-lvm"
#
# Batch 4 (QGA agent-required probes) opt-in. Skipped silently when
# unset. The target VMID must have BOTH:
#   1. PVE-side `agent: 1` set + a full power cycle (warm reboot
#      doesn't pick up the agent flag — qemu only reads it at start).
#   2. Guest-side qemu-guest-agent installed and running. On Alpine:
#         apk add qemu-guest-agent
#         rc-update add qemu-guest-agent default
#         rc-service qemu-guest-agent start
# export PROXXX_E2E_QGA_VMID=8888
