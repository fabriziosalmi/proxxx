# Mission 2 — E2E test environment template.
#
# Copy to your local `test_env` (gitignored) or source directly:
#   $ source tests/e2e.env.example      # NB: edit the values first
#   $ cargo test --release --test e2e_alpha -- --ignored --nocapture
#
# All E2E tests are `#[ignore]`-gated, so a default `cargo test` run
# without these env vars set skips them silently — CI without cluster
# access stays green.

# ── Master gate ─────────────────────────────────────────
# E2eEnv::load() returns None unless this is exactly "1".
export PROXXX_E2E_ENABLE=1

# ── Cluster credentials ─────────────────────────────────
# The token must have at least: VM.Allocate, VM.Audit, VM.PowerMgmt,
# VM.Snapshot, Datastore.Audit on /vms (or scoped to the test VMID).
export PROXXX_E2E_API_URL="https://pve1.lan:8006"
export PROXXX_E2E_USER="root@pam"
export PROXXX_E2E_TOKEN_ID="proxxx-e2e"
export PROXXX_E2E_TOKEN_SECRET="REPLACE-WITH-REAL-SECRET"

# ── Test playground ─────────────────────────────────────
# The node Alpha provisions on, and the VMID it uses. The VMID
# MUST be free at the start of each run — Alpha creates it from
# the configured template, then the RAII guard stops+deletes it
# on teardown.
export PROXXX_E2E_NODE="pve1"
export PROXXX_E2E_VMID="9999"

# ── LXC creation ────────────────────────────────────────
# Alpha provisions a minimal LXC. These are required.
# Find your template list: `pveam available` on the PVE node.
export PROXXX_E2E_TEMPLATE="local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst"
export PROXXX_E2E_STORAGE="local-lvm"

# ── Optional: opt-in destructive delete ─────────────────
# By default Alpha skips the final `proxxx delete --yes` step
# (the RAII guard handles cleanup). Set to 1 to exercise the
# CLI's delete path, validating the V11 401 retry, the V14
# bounded body read, and the V25 lax deserialization end-to-end.
# export PROXXX_E2E_ALLOW_DELETE=1
